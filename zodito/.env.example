# ============================================================================
# ZODITO RENTALS — Environment Variables
# ============================================================================
# Copy this to .env.local and fill in real values. Never commit .env.local.
# ============================================================================

# ---- Clerk (auth) ----
# Get from: https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_d29ya2FibGUtbWFuYXRlZS04Mi5jbGVyay5hY2NvdW50cy5kZXYk
CLERK_SECRET_KEY=sk_test_ye2y8yMRRTfz7RGPycp0gTLT2mYNdLi6dL008cK7U8

# Webhook secret for user sync. Create at:
# Clerk Dashboard → Webhooks → New endpoint → URL: https://yourdomain.com/api/webhooks/clerk
# Subscribe to: user.created, user.updated, user.deleted. Copy the signing secret.
CLERK_WEBHOOK_SECRET=whsec_...

# Optional — redirect URLs after sign in/up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ---- Supabase (database + storage) ----
# Get from: Supabase Dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://svxhcomripoqbxvqzgnf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_mFuQHA0BL65zm0OONxuYLg_OkVUI1Y6
SUPABASE_SERVICE_ROLE_KEY=sb_publishable_mFuQHA0BL65zm0OONxuYLg_OkVUI1Y6

# ---- Razorpay (payments) ----
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_ShIwwFdR1w7ySj
RAZORPAY_KEY_SECRET=M1Aupg67F5QX5gawDLB1sC9r
# Used by the frontend Checkout widget (same as key_id, publicly safe)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...

# Webhook secret — create in Razorpay Dashboard → Settings → Webhooks
# URL: https://yourdomain.com/api/webhooks/razorpay
# Events: payment.captured, payment.failed, order.paid
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ---- App config ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
